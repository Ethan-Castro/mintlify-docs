{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "luma",
  "name": "CSI HPCC Documentation",
  "description": "Documentation and educational guide for the College of Staten Island High Performance Computing Center (CSI HPCC) — clusters, SLURM, storage, tutorials, policies, and support.",
  "colors": {
    "primary": "#1E3A8A",
    "light": "#3B82F6",
    "dark": "#1E40AF"
