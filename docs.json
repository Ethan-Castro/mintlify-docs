          },
          {
            "group": "Systems",
            "pages": [
              "systems",
              "software-modules",
              "applications",
              "storage"
            ]
          },
          {
            "group": "Running jobs",
            "pages": [
              "job-submission"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "policies",
              "pricing-tiers",
              "faqs",
              "changelog"
            ]
          }
        ]
      },
      {
        "tab": "Support",
        "groups": [
          {
            "group": "Help",
            "pages": [
              "support",
              "training"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "HPCC Portal",
          "href": "https://hpchome.csi.cuny.edu",
          "icon": "server"
        },
        {
          "anchor": "HPCC Wiki",
          "href": "https://wiki.csi.cuny.edu/cunyhpc/index.php/Main_Page",
          "icon": "book-open"
        },
        {
          "anchor": "Open a ticket",
          "href": "https://hpchelp.csi.cuny.edu",
          "icon": "life-ring"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "HPC Helpline",
